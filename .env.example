# ── Backend ─────────────────────────────────────────────────
# NODE_ENV=production
# CORS_ORIGIN=https://otakgemuk.github.io
# PORT=3001
# DB_PATH=./data/propfirm.db

# ── Frontend (build-time) ──────────────────────────────────
# VITE_BASE=/prop-firm-api/
# VITE_ADMIN_HASH=<sha256-hex-of-your-admin-password>
#   Generate with: echo -n "yourpassword" | sha256sum | cut -d' ' -f1

# ── Scraper ────────────────────────────────────────────────
# APIFY_API_TOKEN=<your-apify-token>

# ── Data paths ─────────────────────────────────────────────
# DATA_DIR=./data
# DISCOUNTS_PATH=./data/discounts.json
